HOST=0.0.0.0
PORT=5001
FRONTEND_PORT=5173
OPEN_BROWSER=1

IOS_ENABLED=1
IOS_COMMAND_TIMEOUT=15
IOS_WDA_REMOTE_PORT=8100
IOS_LOCAL_PORT_START=18100
IOS_WDA_TIMEOUT=15

# --- WDA auto-launch -------------------------------------------------
# Preferred (NO ADMIN): bundled go-ios starts a USERSPACE RSD tunnel and
# launches WDA via `ios runwda` automatically on connect. Set the bundle id
# to the WDA runner actually installed on your device.
IOS_USE_GOIOS=1
IOS_GOIOS_TUNNEL=1
# Binary resolution: each candidate must pass a `version` usability check.
#   IOS_GOIOS_PREFER_SYSTEM=0 (default): bundled → PATH → extract zip
#   IOS_GOIOS_PREFER_SYSTEM=1          : PATH → bundled → extract zip
# IOS_GOIOS_BIN sets an explicit path that overrides both (if usable).
IOS_GOIOS_PREFER_SYSTEM=0
IOS_GOIOS_BIN=
# Pinned go-ios tunnel-agent HTTP port (deterministic + reclaimable on
# crash/restart). The agent is auto-reclaimed on startup and stopped on exit.
IOS_GOIOS_TUNNEL_INFO_PORT=28100
# Set to the WDA runner actually installed on your device — replace YOURTEAM
# with your own suffix (the value Xcode signed the runner with).
IOS_WDA_BUNDLE_ID=com.facebook.WebDriverAgentRunner.YOURTEAM.test.xctrunner
IOS_WDA_TEST_RUNNER_BUNDLE_ID=
IOS_WDA_XCTEST_CONFIG=WebDriverAgentRunner.xctest
IOS_WDA_LAUNCH_TIMEOUT=40

# Fallback: pymobiledevice3 xcuitest launcher (needs an admin tunneld on
# iOS 17+). Only used when go-ios is disabled/unavailable.
IOS_AUTO_LAUNCH_WDA=0

IOS_SCREEN_PROVIDER=mjpeg
IOS_MJPEG_REMOTE_PORT=9100
# WDA MJPEG broadcaster framerate (WDA caps out ~30-40 on most devices).
IOS_MJPEG_FRAMERATE=30
IOS_MJPEG_QUALITY=60
# Device-side downscale %, 100 = full res. Lower (e.g. 70) = smaller frames =
# cheaper JPEG-decode + H264 re-encode = steadier fps under fast motion.
IOS_MJPEG_SCALING=100
IOS_SCREENSHOT_FPS=8
IOS_STREAM_RECONNECT_INTERVAL=5
# Shared device pool: auto-release a connected device (tear down WDA + forwards)
# after this many seconds with no viewers and no control input. 0 = disabled.
IOS_DEVICE_IDLE_TIMEOUT=300
# USB hotplug watcher poll interval (seconds): re-scan connected devices and
# push devices:changed to all tabs on plug/unplug. 0 = disabled.
IOS_DEVICE_WATCH_INTERVAL=3
IOS_ENABLE_WEBRTC=0

SOCKETIO_PING_TIMEOUT=60
SOCKETIO_PING_INTERVAL=25
